PORT=3001

# Redis / Valkey
VALKEY_URL=rediss://username:password@your-valkey-host:port

# Kafka
KAFKA_BROKER=your-kafka-broker:port
KAFKA_USERNAME=avnadmin
KAFKA_PASSWORD=your_kafka_password

# PostgreSQL
DATABASE_URL=postgres://username:password@your-postgres-host:port/defaultdb?sslmode=require

# MySQL
MYSQL_URI=mysql://username:password@your-mysql-host:port/defaultdb?ssl-mode=REQUIRED
# or use individual MySQL fields:
# MYSQL_HOST=your-mysql-host
# MYSQL_USER=avnadmin
# MYSQL_PASSWORD=your_mysql_password
# MYSQL_DATABASE=defaultdb
# MYSQL_PORT=19488

# OpenSearch
OPENSEARCH_URL=https://your-opensearch-host:port
OPENSEARCH_USERNAME=your_opensearch_user
OPENSEARCH_PASSWORD=your_opensearch_password
OPENSEARCH_INDEX=game-events

# Aiven CA certificate path (optional)
# Use this only if you have a valid custom Aiven CA bundle.
# For publicly trusted Aiven endpoints, you can omit this and use the system trust store.
AIVEN_CA_PATH=./aiven-ca.pem
# Or inject the full PEM content directly
# AIVEN_CA_CERT="-----BEGIN CERTIFICATE-----..."